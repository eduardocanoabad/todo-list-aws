pipeline {
  agent any
  stages {
    stage('Set environment') {
            parallel {
              stage('Agent1 setup') {
                agent { label 'Agent1' }
                steps {
                  catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                      python3 -m venv venv
                      ./venv/bin/python -m pip install --upgrade pip
                      ./venv/bin/pip install -r requirements.txt
                    '''
                  }
                }
              }
              stage('Agent2 setup') {
                agent { label 'Agent2' }
                steps {
                  catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                      python3 -m venv venv
                      ./venv/bin/python -m pip install --upgrade pip
                      ./venv/bin/pip install -r requirements.txt
                    '''
                  }
                }
              }
            }
          }
        stage('Deploy SAM') {
        agent { label 'Agent1' }
          steps {
            catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
              sh '''
                export PYTHONPATH=$PWD
                sam --version
                sam build --template-file template.yaml
                sam deploy --config-file samconfig.toml --config-env production --no-confirm-changeset --no-fail-on-empty-changeset
              '''
            }
          }
        }

        stage('Run Tests') {
        agent { label 'Agent2' }
          steps {
            catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
              sh '''
                export PYTHONPATH=$PWD

                BASE_URL=$(aws cloudformation describe-stacks \
                  --stack-name todo-list-aws-production \
                  --region us-east-1 \
                  --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' \
                  --output text)

                export BASE_URL
                echo "BASE_URL=$BASE_URL"

                ./venv/bin/pytest test/integration/todoApiTest.py::TestApi::test_api_listtodos --junitxml=result_listtodos.xml
                ./venv/bin/pytest test/integration/todoApiTest.py::TestApi::test_api_gettodo --junitxml=result_gettodo.xml
              '''
            }
            junit testResults: 'result_*.xml'
          }
        }
  }
}
